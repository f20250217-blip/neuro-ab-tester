{
  "manifest_version": 3,
  "name": "NeuroTest AI — Brain Activity Monitor",
  "version": "1.0.0",
  "description": "See what your browsing does to your brain. Real-time neural mapping of your digital behavior.",
  "permissions": ["history", "tabs", "activeTab", "storage", "alarms"],
  "host_permissions": ["https://neurotest.live/*", "http://localhost:3000/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
